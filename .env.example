# Supabase → Settings → Database → Connection string (tombol Connect)
#
# Vercel / hosting: isi DATABASE_URL dan DIRECT_URL di Environment Variables.
# Jangan pakai tanda kutip di sekitar nilai. Keduanya harus diawali postgresql://
#
# Disarankan: DATABASE_URL = Transaction pooler :6543 (+ pgbouncer=true)
#             DIRECT_URL   = Direct :5432 (db.PROJECT_REF.supabase.co)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

ADMIN_USERNAME="admin"
ADMIN_PASSWORD="ganti-password-kuat"
SESSION_SECRET="ganti-dengan-string-acak-panjang"
